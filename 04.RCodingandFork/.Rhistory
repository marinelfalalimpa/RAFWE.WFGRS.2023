revcommanalysis<-subset(d,select = c(Sex,Season,BodyCond,Heterophils,Lymphocytes,Eosinophils,Monocytes,Basophils),)
comm_long<-melt(revcommanalysis,id.vars=c("Sex","Season","BodyCond"),variable.name="Cell_Type")
commgraph <- ggplot(comm_long) + geom_bar(position="fill",stat="identity",aes(x=Sex,y=value,fill=Cell_Type))+scale_fill_manual(values=(col=myCol))+
theme(axis.text=element_text(size=10))
commgraph+ylab("Proportion of Total Leukocytes")+ggtitle("Leukocyte Composition")
